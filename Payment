<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vampnails444 Payment</title>
   
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   
    <style>
        body {
            font-family: 'Prompt', sans-serif;
            background: linear-gradient(135deg, #241a22 0%, #372d36 100%);
            min-height: 100vh;
            color: #f5e0df;
        }
       
        @keyframes float-up-down {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(10deg); }
        }
        @keyframes dash-animation {
            from { stroke-dashoffset: 0; }
            to { stroke-dashoffset: -24; }
        }
        .animate-dash { animation: dash-animation 1s linear infinite; }
        .anim-float-1 { animation: float-up-down 4s ease-in-out infinite; }
        .anim-pulse { animation: pulse-soft 3s ease-in-out infinite; }
        @keyframes pulse-soft { 0%, 100% { opacity: 0.6; } 50% { opacity: 1; } }
        
        .glass-card {
            background: rgba(55, 45, 54, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(229, 169, 191, 0.2);
            box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5);
        }
        .virtual-card { transition: all 0.3s ease; }
        .virtual-card:active { transform: scale(0.98); }
        ::-webkit-scrollbar { width: 0px; }
    </style>
   
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        vamp: {
                            dark: '#241a22',
                            mid: '#372d36',
                            pink: '#e5a9bf',
                            light: '#fdd6dd',
                            cream: '#f5e0df'
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="flex flex-col items-center py-6 px-4 relative overflow-x-hidden">
    <div class="fixed inset-0 pointer-events-none z-0">
        <svg class="absolute top-[5%] left-[10%] w-8 h-8 text-vamp-pink/20 anim-float-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
        <svg class="absolute bottom-[10%] right-[10%] w-10 h-10 text-vamp-light/10 anim-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
    </div>

    <div id="toast" class="fixed bottom-8 left-1/2 transform -translate-x-1/2 bg-vamp-pink text-vamp-dark px-6 py-3 rounded-full shadow-xl transition-all duration-300 opacity-0 translate-y-4 pointer-events-none z-50 flex items-center gap-2 font-bold text-sm">
        คัดลอกเลขบัญชีแล้ว ✨
    </div>

    <div class="max-w-[420px] w-full relative z-10 space-y-5 pb-10">
        <div class="text-center pt-2">
            <img src="phonto.png" alt="Logo" class="w-20 h-20 mx-auto mb-2 rounded-full shadow-md border-2 border-vamp-pink object-cover">
            <h1 class="text-2xl font-bold text-vamp-pink">Vampnails444</h1>
            <p class="text-sm text-vamp-pink/70">Payment & Checkout</p>
        </div>

        <div class="glass-card rounded-[40px] p-3">
            <div class="relative p-2 rounded-[36px]">
                <svg class="absolute inset-0 w-full h-full pointer-events-none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="calc(100% - 4px)" height="calc(100% - 4px)" rx="34" fill="none" stroke="#e5a9bf" stroke-width="2.5" stroke-dasharray="12 12" stroke-linecap="round" class="animate-dash" />
                </svg>
                <div class="rounded-[28px] overflow-hidden border-[4px] border-vamp-mid">
                    <img src="หงิง07_20260403212708.png" alt="QR" class="w-full h-auto">
                </div>
            </div>

            <div class="p-4 pt-6 space-y-5">
                <div class="text-center">
                    <p class="text-[15px] text-vamp-cream">
                        เลขบัญชีตามนี้เลยค่า ✨<br>
                        ชื่อบัญชี <span class="text-vamp-dark font-bold bg-vamp-pink px-2.5 py-0.5 rounded-lg">ภัทรนันท์ บุญรักกว้าง</span>
                    </p>
                </div>

                <div class="space-y-4">
                    <div class="virtual-card bg-gradient-to-br from-vamp-mid to-vamp-dark rounded-[24px] p-5 shadow-lg cursor-pointer border border-vamp-pink/20" onclick="copyText('0578115617', this, 'kbank')">
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-vamp-dark font-bold text-sm bg-vamp-pink px-3 py-1.5 rounded-full">KBank</span>
                            <button class="kbank-btn bg-vamp-cream text-vamp-dark text-[12px] font-bold px-4 py-2 rounded-full">คัดลอก</button>
                        </div>
                        <div class="text-vamp-pink text-[11px] mb-1">กสิกรไทย (ภัทรนันท์)</div>
                        <div class="text-vamp-light font-bold text-[22px] tracking-widest">057-811-5617</div>
                    </div>

                    <div class="virtual-card bg-gradient-to-br from-vamp-pink to-vamp-mid rounded-[24px] p-5 shadow-lg cursor-pointer border border-vamp-light/30" onclick="copyText('0996325583', this, 'true')">
                        <div class="flex justify-between items-center mb-4">
                            <span class="text-vamp-dark font-bold text-sm bg-vamp-light px-3 py-1.5 rounded-full">TrueMoney</span>
                            <button class="true-btn bg-vamp-dark text-vamp-light text-[12px] font-bold px-4 py-2 rounded-full">คัดลอก</button>
                        </div>
                        <div class="text-vamp-dark/70 font-medium text-[11px] mb-1">ทรูมันนี่ (ภัทรนันท์)</div>
                        <div class="text-vamp-dark font-bold text-[22px] tracking-widest">099-632-5583</div>
                    </div>

                    <div class="bg-vamp-pink/10 border border-vamp-pink/30 rounded-2xl p-3 text-[13px] text-center">
                        โอนแล้วรบกวน <span class="text-vamp-pink font-bold underline">แปะสลิปทุกครั้ง</span> ด้วยน้า
                    </div>
                </div>
            </div>
        </div>
        
        <div class="text-center text-[11px] text-vamp-pink/50">
            ขอบคุณที่มาอุดหนุนน้าา 💖 ชำระแล้วส่งสลิปได้เลยคีบ
        </div>
    </div>

    <script>
        function copyText(text, containerElement, type) {
            navigator.clipboard.writeText(text).then(() => {
                showToast();
                const btn = containerElement.querySelector(type === 'kbank' ? '.kbank-btn' : '.true-btn');
                const oldText = btn.innerText;
                btn.innerText = 'สำเร็จ!';
                setTimeout(() => btn.innerText = oldText, 2000);
            });
        }
        function showToast() {
            const t = document.getElementById('toast');
            t.classList.replace('opacity-0', 'opacity-100');
            t.classList.replace('translate-y-4', 'translate-y-0');
            setTimeout(() => {
                t.classList.replace('opacity-100', 'opacity-0');
                t.classList.replace('translate-y-0', 'translate-y-4');
            }, 2000);
        }
    </script>
</body>
</html>
