<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vampnails444 Payment</title>
   
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600;700&display=swap" rel="stylesheet">
   
    <style>
        body {
            font-family: 'Prompt', sans-serif;
            /* ใช้สีเข้ม #241a22 เป็นพื้นหลัก ตัดด้วย #372d36 */
            background: linear-gradient(135deg, #241a22 0%, #372d36 100%);
            min-height: 100vh;
            color: #f5e0df;
        }
       
        @keyframes float-up-down {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-15px) rotate(10deg); }
        }
        @keyframes float-left-right {
            0%, 100% { transform: translateX(0px) rotate(0deg); }
            50% { transform: translateX(15px) rotate(-10deg); }
        }
        @keyframes pulse-soft {
            0%, 100% { transform: scale(1); opacity: 0.8; }
            50% { transform: scale(1.1); opacity: 1; }
        }
        @keyframes spin-slow { 100% { transform: rotate(360deg); } }
        @keyframes dash-animation {
            from { stroke-dashoffset: 0; }
            to { stroke-dashoffset: -24; }
        }
        .animate-dash {
            animation: dash-animation 1s linear infinite;
        }
        .anim-float-1 { animation: float-up-down 4s ease-in-out infinite; }
        .anim-float-2 { animation: float-up-down 5s ease-in-out infinite 1.5s; }
        .anim-float-3 { animation: float-left-right 6s ease-in-out infinite; }
        .anim-float-4 { animation: float-left-right 4.5s ease-in-out infinite 2s; }
        .anim-pulse { animation: pulse-soft 3s ease-in-out infinite; }
        .anim-spin { animation: spin-slow 8s linear infinite; }
        
        .glass-card {
            /* ปรับ Background Card เป็นสีเข้มโปร่งแสงตามโทนใหม่ */
            background: rgba(55, 45, 54, 0.8);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(229, 169, 191, 0.2);
            box-shadow: 0 20px 50px -10px rgba(0, 0, 0, 0.5),
                        inset 0 2px 10px rgba(255, 255, 255, 0.05);
        }
        .virtual-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .virtual-card:hover {
            transform: translateY(-4px);
        }
        .virtual-card:active {
            transform: translateY(2px) scale(0.98);
        }
       
        ::-webkit-scrollbar {
            width: 0px;
        }
    </style>
   
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        vamp: {
                            dark: '#241a22',
                            mid: '#372d36',
                            pink: '#e5a9bf',
                            light: '#fdd6dd',
                            cream: '#f5e0df'
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="flex flex-col items-center py-6 px-4 relative overflow-x-hidden">
    <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
        <svg class="absolute top-[5%] left-[10%] w-8 h-8 text-vamp-pink/30 anim-float-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
        <svg class="absolute top-[15%] left-[2%] w-6 h-6 text-vamp-light/20 anim-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <svg class="absolute top-[40%] -left-2 w-12 h-12 text-vamp-mid anim-pulse" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <svg class="absolute bottom-[5%] right-[15%] w-7 h-7 text-vamp-pink/20 anim-float-2" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/></svg>
    </div>

    <div id="toast" class="fixed bottom-8 left-1/2 transform -translate-x-1/2 bg-vamp-pink text-vamp-dark px-6 py-3 rounded-full shadow-xl transition-all duration-300 opacity-0 translate-y-4 pointer-events-none z-50 flex items-center gap-2 font-bold text-sm border border-vamp-light">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        คัดลอกเลขบัญชีแล้ว
    </div>

    <div class="max-w-[420px] w-full relative z-10 space-y-5 pb-10">
        <div class="text-center pt-2 pb-2 relative">
            <img src="phonto.jpeg" alt="Logo" class="w-20 h-20 mx-auto mb-2 rounded-full shadow-md border-2 border-vamp-pink object-cover" onerror="this.style.display='none'">
            <h1 class="text-2xl font-bold tracking-tight text-vamp-pink flex items-center justify-center gap-2">
                Vampnails444
            </h1>
            <p class="text-sm font-medium text-vamp-pink/70 mt-1">Payment & Checkout</p>
        </div>

        <div class="glass-card rounded-[40px] p-3 relative z-10">
            <div class="relative p-2 rounded-[36px] z-10">
                <svg class="absolute inset-0 w-full h-full pointer-events-none" xmlns="http://www.w3.org/2000/svg">
                    <rect x="2" y="2" width="calc(100% - 4px)" height="calc(100% - 4px)" rx="34" fill="none" stroke="#e5a9bf" stroke-width="2.5" stroke-dasharray="12 12" stroke-linecap="round" class="animate-dash" />
                </svg>
                <div class="rounded-[28px] overflow-hidden relative shadow-sm border-[4px] border-vamp-mid">
                    <img src="หงิง07_20260403212708.png" alt="QR Payment" class="w-full h-auto object-cover" onerror="this.src='https://placehold.co/600x600/372d36/e5a9bf?text=Scan+to+Pay'">
                </div>
            </div>

            <div class="p-4 pt-6 space-y-5">
                <div class="text-center space-y-3">
                    <p class="text-[15px] font-medium leading-relaxed text-vamp-cream">
                        เลขบัญชีตามนี้เลยค่า ✨<br>
                        ชื่อบัญชี <span class="text-vamp-dark font-bold bg-vamp-pink px-2.5 py-0.5 rounded-lg relative inline-block">
                            ภัทรนันท์ บุญรักกว้าง
                        </span> เท่านั้นน้า!!
                    </p>
                </div>

                <div class="space-y-4">
                    <div class="virtual-card relative bg-gradient-to-br from-vamp-mid to-vamp-dark rounded-[24px] p-5 shadow-lg cursor-pointer border border-vamp-pink/20" onclick="copyText('0578115617', this, 'kbank')">
                        <div class="relative z-10 flex flex-col gap-4">
                            <div class="flex justify-between items-center">
                                <span class="text-vamp-dark font-bold text-sm bg-vamp-pink px-3 py-1.5 rounded-full">KBank</span>
                                <button class="kbank-btn bg-vamp-cream text-vamp-dark text-[12px] font-bold px-4 py-2 rounded-full shadow-sm pointer-events-none">คัดลอก</button>
                            </div>
                            <div class="mt-2">
                                <div class="text-vamp-pink text-[11px] font-medium mb-1">กสิกรไทย (ภัทรนันท์)</div>
                                <div class="text-vamp-light font-bold text-[22px] tracking-widest">057-811-5617</div>
                            </div>
                        </div>
                    </div>

                    <div class="virtual-card relative bg-gradient-to-br from-vamp-pink to-vamp-mid rounded-[24px] p-5 shadow-lg cursor-pointer border border-vamp-light/30" onclick="copyText('0996325583', this, 'true')">
                        <div class="relative z-10 flex flex-col gap-4">
                            <div class="flex justify-between items-center">
                                <span class="text-vamp-dark font-bold text-sm bg-vamp-light px-3 py-1.5 rounded-full">TrueMoney</span>
                                <button class="true-btn bg-vamp-dark text-vamp-light text-[12px] font-bold px-4 py-2 rounded-full shadow-sm pointer-events-none">คัดลอก</button>
                            </div>
                            <div class="mt-2">
                                <div class="text-vamp-dark font-medium text-[11px] mb-1">ทรูมันนี่ (ภัทรนันท์)</div>
                                <div class="text-vamp-dark font-bold text-[22px] tracking-widest">099-632-5583</div>
                            </div>
                        </div>
                    </div>

                    <div class="bg-gradient-to-br from-vamp-mid to-vamp-dark rounded-[20px] p-3.5 border-2 border-dashed border-vamp-pink/50 mt-1">
                        <div class="flex items-start gap-3">
                            <div class="bg-vamp-pink p-1.5 rounded-full text-vamp-dark animate-bounce mt-1">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
                            </div>
                            <div class="text-[11.5px] text-vamp-cream">
                                <span class="bg-vamp-light text-vamp-dark text-[9px] font-bold px-2 py-0.5 rounded-full mb-1 tracking-wider">โปรดทราบ</span><br>
                                กรุณาตรวจสอบยอดโอนให้ถูกต้องก่อนกดยืนยันนะคะ
                            </div>
                        </div>
                    </div>

                    <div class="bg-vamp-pink/10 border border-vamp-pink/30 rounded-2xl p-3 text-[13px] font-medium text-vamp-light">
                        โอนแล้วรบกวน <span class="text-vamp-pink font-bold underline">แปะสลิปทุกครั้ง</span> ด้วยน้า
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center flex flex-col items-center justify-center gap-1.5 text-[11px] text-vamp-pink/50 pt-1 relative z-10">
            <div class="flex items-center gap-1 font-medium text-vamp-pink">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 anim-pulse" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 20.25c4.97 0 9-3.694 9-8.25s-4.03-8.25-9-8.25S3 7.444 3 12c0 2.104.859 4.023 2.273 5.48.432.447.74 1.04.586 1.641a4.483 4.483 0 01-.923 1.785A5.969 5.969 0 006 21c1.282 0 2.47-.402 3.445-1.087.81.22 1.668.337 2.555.337z" /></svg>
                ขอบคุณที่มาอุดหนุนน้าา
            </div>
            ชำระแล้วส่งสลิปในแชทได้เลยค่ะ
        </div>
    </div>
    <script>
        function copyText(text, containerElement, type) {
            const textArea = document.createElement("textarea");
            textArea.value = text;
            textArea.style.position = "fixed";
            textArea.style.left = "-999999px";
            textArea.style.top = "-999999px";
            document.body.appendChild(textArea);
            textArea.focus();
            textArea.select();
            try {
                document.execCommand('copy');
                showToast();
                
                const buttonElement = containerElement.querySelector(type === 'kbank' ? '.kbank-btn' : '.true-btn');
                const originalHtml = buttonElement.innerHTML;
               
                buttonElement.innerHTML = `สำเร็จ`;
                // ปรับสีปุ่มตอนกดให้เข้ากับโทนใหม่
                buttonElement.style.backgroundColor = '#fdd6dd';
                buttonElement.style.color = '#241a22';
               
                setTimeout(() => {
                    buttonElement.innerHTML = originalHtml;
                    buttonElement.style.backgroundColor = '';
                    buttonElement.style.color = '';
                }, 2000);
            } catch (err) {
                console.error('ไม่สามารถคัดลอกได้:', err);
            }
            document.body.removeChild(textArea);
        }

        function showToast() {
            const toast = document.getElementById('toast');
            toast.classList.remove('opacity-0', 'translate-y-4');
            toast.classList.add('opacity-100', 'translate-y-0');
            setTimeout(() => {
                toast.classList.remove('opacity-100', 'translate-y-0');
                toast.classList.add('opacity-0', 'translate-y-4');
            }, 2500);
        }
    </script>
</body>
</html>
